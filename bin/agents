#!/bin/sh
# agents: instalador de agentes via terminal (Codex, Claude, OpenCode).
# Uso: agents <install|list|update|remove> [args]

set -eu

# Resolve symlinks para achar a raiz real (AGENTS_HOME sobrescreve, se definido).
prog=$0
while [ -L "$prog" ]; do
  link=$(readlink "$prog")
  case "$link" in
    /*) prog=$link ;;
    *) prog=$(dirname -- "$prog")/$link ;;
  esac
done
AGENTS_HOME=${AGENTS_HOME:-$(CDPATH='' cd -- "$(dirname -- "$prog")/.." && pwd)}
export AGENTS_HOME

LIB="$AGENTS_HOME/lib"
CONF="$AGENTS_HOME/targets.conf"
export CONF

# shellcheck source=/dev/null
. "$LIB/manifest.sh"
# shellcheck source=/dev/null
. "$LIB/targets.sh"
# shellcheck source=/dev/null
. "$LIB/lock.sh"
# shellcheck source=/dev/null
. "$LIB/plan.sh"
# shellcheck source=/dev/null
. "$LIB/render.sh"
# shellcheck source=/dev/null
. "$LIB/tui.sh"
# shellcheck source=/dev/null
. "$LIB/selfupdate.sh"
# shellcheck source=/dev/null
. "$LIB/commands/install.sh"
# shellcheck source=/dev/null
. "$LIB/commands/list.sh"
# shellcheck source=/dev/null
. "$LIB/commands/update.sh"
# shellcheck source=/dev/null
. "$LIB/commands/remove.sh"

usage() {
  cat <<'EOF'
agents - instalador de agentes via terminal

Uso:
  agents install <nome> [--target <claude|codex|opencode>]
  agents list [--installed]
  agents update <nome>
  agents remove <nome>
  agents --update              # atualiza o agents e os agentes instalados aqui

O alvo e detectado pelo projeto quando possivel; --target tem precedencia.
Ao rodar em um terminal, o agents avisa (1x/dia) se houver atualizacao dele
proprio. Desative com AGENTS_NO_UPDATE_CHECK=1.
EOF
}

cmd=${1:-}
[ "$#" -gt 0 ] && shift || true

# Check de auto atualizacao antes de executar (so em terminal; nunca para --update/help).
case "$cmd" in
  --update | -h | --help | help | "") : ;;
  *)
    if [ -t 0 ] && [ -r /dev/tty ] && [ -w /dev/tty ] && [ -z "${AGENTS_NO_UPDATE_CHECK:-}" ]; then
      self_update_check
    fi
    ;;
esac

case "$cmd" in
  install) cmd_install "$@" ;;
  list) cmd_list "$@" ;;
  update) cmd_update "$@" ;;
  remove) cmd_remove "$@" ;;
  --update) self_update ;;
  -h | --help | help | "") usage ;;
  *)
    printf 'erro: comando desconhecido "%s"\n\n' "$cmd" >&2
    usage >&2
    exit 2
    ;;
esac
